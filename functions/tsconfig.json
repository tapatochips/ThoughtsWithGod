{
    "compilerOptions": {
        "target": "es2017",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "lib"
    },
    "include": [
        "index.tsx"
    ],
    "exclude": [
        "lib",
        "node_modules"
    ]
}